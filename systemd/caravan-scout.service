[Unit]
Description=Caravan Scout (lama-caravan client agent)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/projects/caravan-scout
ExecStart=/usr/bin/python3 -m caravan_scout.app --config %h/projects/caravan-scout/config.json --state %h/projects/caravan-scout/state.json
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
